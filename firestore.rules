rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /artifacts/{appId}/users/{userId}/transactions
    // Document ID: auto-generated
    // Fields:
    //   - amount: number (required, > 0)
    //   - type: string (required, 'expense' or 'income')
    //   - category: string (required, < 50 chars)
    //   - wallet: string (required, < 50 chars)
    //   - note: string (optional, < 200 chars)
    //   - date: string (required, ISO 8601 format)
    //   - timestamp: number (required)
    //
    // Collection: /artifacts/{appId}/users/{userId}/wallets
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 50 chars)
    //   - balance: number (required)
    //
    // Collection: /artifacts/{appId}/users/{userId}/categories
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 50 chars)
    //
    // Collection: /artifacts/{appId}/users/{userId}/settings/profile
    // Document ID: 'profile'
    // Fields:
    //   - name: string (required, < 50 chars)
    //   - photo: string (optional, URL)
    //   - language: string (optional, 'en', 'id', 'zh', 'ja')
    //   - isPremium: boolean (optional)
    //   - licenseCode: string (optional, < 100 chars)
    //
    // Collection: /artifacts/{appId}/users/{userId}/settings/budget
    // Document ID: 'budget'
    // Fields:
    //   - monthlyIncome: number (required)
    //   - savingsGoal: number (required)
    //
    // Collection: /artifacts/{appId}/users/{userId}/reminders
    // Document ID: auto-generated
    // Fields:
    //   - type: string (required, 'daily', 'budget', 'subscription')
    //   - message: string (required)
    //   - status: string (required, 'unread', 'read')
    //   - createdAt: number (required)
    //
    // Collection: /artifacts/{appId}/users/{userId}/insights
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - createdAt: number (required)
    //
    // Collection: /artifacts/{appId}/users/{userId}/receipts
    // Document ID: auto-generated
    // Fields:
    //   - imageUrl: string (required)
    //   - detectedTotal: number (optional)
    //   - detectedStore: string (optional)
    //   - transactionId: string (optional)
    //   - createdAt: number (required)
    //
    // Collection: /artifacts/{appId}/users/{userId}/financial_scores
    // Document ID: auto-generated
    // Fields:
    //   - score: number (required, 0-100)
    //   - calculatedAt: number (required)
    //
    // Collection: /artifacts/{appId}/users/{userId}/saving_goals
    // Document ID: auto-generated
    // Fields:
    //   - goalName: string (required)
    //   - targetAmount: number (required)
    //   - currentSaved: number (required)
    //   - deadline: string (optional)
    //   - createdAt: number (required)
    //
    // Collection: /artifacts/{appId}/license_requests_v3/{requestId}
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - userEmail: string (optional)
    //   - userName: string (optional)
    //   - status: string (required, 'pending', 'approved', 'rejected')
    //   - timestamp: number (required)
    //   - paymentMethod: string (optional)
    //   - paymentProof: string (required, base64 image)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "muhamadnugiandri@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    function isValidOptionalString(field, min, max) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= min && 
              request.resource.data[field].size() <= max);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTransaction() {
      return hasRequiredFields(['amount', 'type', 'category', 'wallet', 'date', 'timestamp']) &&
             hasOnlyAllowedFields(['amount', 'type', 'category', 'wallet', 'date', 'timestamp', 'note']) &&
             request.resource.data.amount is number && request.resource.data.amount > 0 &&
             request.resource.data.type in ['expense', 'income'] &&
             isValidString('category', 1, 50) &&
             isValidString('wallet', 1, 50) &&
             isValidString('date', 10, 30) &&
             request.resource.data.timestamp is number &&
             isValidOptionalString('note', 0, 200);
    }

    function isValidWallet() {
      return hasRequiredFields(['name', 'balance']) &&
             hasOnlyAllowedFields(['name', 'balance']) &&
             isValidString('name', 1, 50) &&
             request.resource.data.balance is number;
    }

    function isValidCategory() {
      return hasRequiredFields(['name']) &&
             hasOnlyAllowedFields(['name']) &&
             isValidString('name', 1, 50);
    }

    function isValidProfile() {
      return hasRequiredFields(['name']) &&
             hasOnlyAllowedFields(['name', 'photo', 'language', 'isPremium', 'licenseCode']) &&
             isValidString('name', 1, 50) &&
             isValidOptionalString('photo', 0, 500) &&
             (!( 'language' in request.resource.data) || request.resource.data.language in ['en', 'id', 'zh', 'ja']) &&
             (!( 'isPremium' in request.resource.data) || request.resource.data.isPremium is bool) &&
             isValidOptionalString('licenseCode', 0, 100);
    }

    function isValidLicenseRequest() {
      return hasRequiredFields(['userId', 'status', 'timestamp', 'paymentProof']) &&
             hasOnlyAllowedFields(['userId', 'userEmail', 'userName', 'status', 'timestamp', 'paymentMethod', 'paymentProof']) &&
             request.resource.data.userId is string &&
             request.resource.data.status in ['pending', 'approved', 'rejected'] &&
             request.resource.data.timestamp is number &&
             request.resource.data.paymentProof is string &&
             request.resource.data.paymentProof.size() < 1000000; // Limit size
    }

    function isValidBudget() {
      return hasRequiredFields(['monthlyIncome', 'savingsGoal']) &&
             hasOnlyAllowedFields(['monthlyIncome', 'savingsGoal']) &&
             request.resource.data.monthlyIncome is number &&
             request.resource.data.savingsGoal is number;
    }

    function isValidReminder() {
      return hasRequiredFields(['type', 'message', 'status', 'createdAt']) &&
             request.resource.data.type in ['daily', 'budget', 'subscription'] &&
             request.resource.data.status in ['unread', 'read'] &&
             request.resource.data.createdAt is number;
    }

    function isValidInsight() {
      return hasRequiredFields(['title', 'description', 'createdAt']) &&
             request.resource.data.title is string &&
             request.resource.data.description is string &&
             request.resource.data.createdAt is number;
    }

    function isValidReceipt() {
      return hasRequiredFields(['imageUrl', 'createdAt']) &&
             request.resource.data.imageUrl is string &&
             request.resource.data.createdAt is number;
    }

    function isValidFinancialScore() {
      return hasRequiredFields(['score', 'calculatedAt']) &&
             request.resource.data.score is number &&
             request.resource.data.score >= 0 && request.resource.data.score <= 100 &&
             request.resource.data.calculatedAt is number;
    }

    function isValidSavingGoal() {
      return hasRequiredFields(['goalName', 'targetAmount', 'currentSaved', 'createdAt']) &&
             request.resource.data.goalName is string &&
             request.resource.data.targetAmount is number &&
             request.resource.data.currentSaved is number &&
             request.resource.data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /artifacts/{appId}/license_requests_v3/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated() && isValidLicenseRequest() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidLicenseRequest();
      allow delete: if isAdmin();
    }

    match /artifacts/{appId}/users/{userId} {
      
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction();
        allow update: if isOwner(userId) && isValidTransaction();
        allow delete: if isOwner(userId);
      }

      match /wallets/{walletId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWallet();
        allow update: if isOwner(userId) && isValidWallet();
        allow delete: if isOwner(userId);
      }

      match /categories/{categoryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCategory();
        allow update: if isOwner(userId) && isValidCategory();
        allow delete: if isOwner(userId);
      }

      match /settings/profile {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidProfile() && 
                      (!('isPremium' in request.resource.data) || request.resource.data.isPremium == false);
        allow update: if (isOwner(userId) && isValidProfile() && 
                         (!('isPremium' in request.resource.data) || request.resource.data.isPremium == resource.data.isPremium) &&
                         (!('licenseCode' in request.resource.data) || request.resource.data.licenseCode == resource.data.licenseCode)) ||
                      (isAdmin() && isValidProfile());
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /settings/budget {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBudget();
        allow update: if isOwner(userId) && isValidBudget();
        allow delete: if isOwner(userId);
      }

      match /reminders/{reminderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReminder();
        allow update: if isOwner(userId) && isValidReminder();
        allow delete: if isOwner(userId);
      }

      match /insights/{insightId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInsight();
        allow update: if isOwner(userId) && isValidInsight();
        allow delete: if isOwner(userId);
      }

      match /receipts/{receiptId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidReceipt();
        allow update: if isOwner(userId) && isValidReceipt();
        allow delete: if isOwner(userId);
      }

      match /financial_scores/{scoreId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFinancialScore();
        allow update: if isOwner(userId) && isValidFinancialScore();
        allow delete: if isOwner(userId);
      }

      match /saving_goals/{goalId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSavingGoal();
        allow update: if isOwner(userId) && isValidSavingGoal();
        allow delete: if isOwner(userId);
      }
    }
  }
}
