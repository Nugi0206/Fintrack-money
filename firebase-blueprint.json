{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense).",
      "type": "object",
      "properties": {
        "amount": { "type": "number", "description": "The amount of the transaction." },
        "type": { "type": "string", "enum": ["expense", "income"], "description": "The type of transaction." },
        "category": { "type": "string", "description": "The category name." },
        "wallet": { "type": "string", "description": "The wallet name used." },
        "note": { "type": "string", "description": "Optional note for the transaction." },
        "date": { "type": "string", "format": "date", "description": "The date of the transaction (YYYY-MM-DD)." },
        "timestamp": { "type": "number", "description": "Unix timestamp of the transaction." }
      },
      "required": ["amount", "type", "category", "wallet", "date", "timestamp"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "A financial wallet or account.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the wallet." },
        "balance": { "type": "number", "description": "The initial or current balance." }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "A transaction category.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the category." }
      },
      "required": ["name"]
    },
    "Profile": {
      "title": "Profile",
      "description": "User profile settings.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's display name." },
        "photo": { "type": "string", "description": "The user's profile photo URL." },
        "language": { "type": "string", "enum": ["en", "id", "zh", "ja"], "description": "User's preferred language." },
        "isPremium": { "type": "boolean", "description": "Whether the user has a premium license." },
        "licenseCode": { "type": "string", "description": "The user's unique license code." }
      },
      "required": ["name"]
    },
    "Budget": {
      "title": "Budget",
      "description": "User's budget and savings goals.",
      "type": "object",
      "properties": {
        "monthlyIncome": { "type": "number", "description": "The user's monthly income." },
        "savingsGoal": { "type": "number", "description": "The user's savings goal percentage." }
      },
      "required": ["monthlyIncome", "savingsGoal"]
    },
    "LicenseRequest": {
      "title": "LicenseRequest",
      "description": "A request for a premium license after payment.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user requesting the license." },
        "userEmail": { "type": "string", "description": "The email of the user." },
        "userName": { "type": "string", "description": "The name of the user." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "The status of the request." },
        "timestamp": { "type": "number", "description": "When the request was made." },
        "paymentMethod": { "type": "string", "description": "DANA or BCA." },
        "paymentProof": { "type": "string", "description": "Base64 image of payment proof." }
      },
      "required": ["userId", "status", "timestamp", "paymentProof"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A smart notification for the user.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["daily", "budget", "subscription"], "description": "Type of reminder." },
        "message": { "type": "string", "description": "The reminder message." },
        "status": { "type": "string", "enum": ["unread", "read"], "description": "Status of the reminder." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["type", "message", "status", "createdAt"]
    },
    "Insight": {
      "title": "Insight",
      "description": "AI-generated spending insight.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Insight title." },
        "description": { "type": "string", "description": "Detailed insight description." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["title", "description", "createdAt"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Scanned receipt data.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string", "description": "Base64 or URL of the receipt image." },
        "detectedTotal": { "type": "number", "description": "Total amount extracted." },
        "detectedStore": { "type": "string", "description": "Store name extracted." },
        "transactionId": { "type": "string", "description": "Linked transaction ID." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["imageUrl", "createdAt"]
    },
    "FinancialScore": {
      "title": "FinancialScore",
      "description": "User's financial health score.",
      "type": "object",
      "properties": {
        "score": { "type": "number", "description": "Score from 0 to 100." },
        "calculatedAt": { "type": "number", "description": "Timestamp of calculation." }
      },
      "required": ["score", "calculatedAt"]
    },
    "SavingGoal": {
      "title": "SavingGoal",
      "description": "A goal for saving money.",
      "type": "object",
      "properties": {
        "goalName": { "type": "string", "description": "Name of the goal." },
        "targetAmount": { "type": "number", "description": "Target amount to save." },
        "currentSaved": { "type": "number", "description": "Amount currently saved." },
        "deadline": { "type": "string", "format": "date", "description": "Deadline for the goal." },
        "createdAt": { "type": "number", "description": "Timestamp of creation." }
      },
      "required": ["goalName", "targetAmount", "currentSaved", "createdAt"]
    }
  },
  "firestore": {
    "/artifacts/{appId}/license_requests_v3/{requestId}": {
      "schema": "LicenseRequest",
      "description": "Global license requests for admin approval."
    },
    "/artifacts/{appId}/users/{userId}/transactions": {
      "schema": "Transaction",
      "description": "User's financial transactions."
    },
    "/artifacts/{appId}/users/{userId}/wallets": {
      "schema": "Wallet",
      "description": "User's wallets/accounts."
    },
    "/artifacts/{appId}/users/{userId}/categories": {
      "schema": "Category",
      "description": "User's transaction categories."
    },
    "/artifacts/{appId}/users/{userId}/settings/profile": {
      "schema": "Profile",
      "description": "User's profile settings."
    },
    "/artifacts/{appId}/users/{userId}/settings/budget": {
      "schema": "Budget",
      "description": "User's budget settings."
    },
    "/artifacts/{appId}/users/{userId}/reminders": {
      "schema": "Reminder",
      "description": "User's smart reminders."
    },
    "/artifacts/{appId}/users/{userId}/insights": {
      "schema": "Insight",
      "description": "User's AI insights."
    },
    "/artifacts/{appId}/users/{userId}/receipts": {
      "schema": "Receipt",
      "description": "User's scanned receipts."
    },
    "/artifacts/{appId}/users/{userId}/financial_scores": {
      "schema": "FinancialScore",
      "description": "User's financial health scores."
    },
    "/artifacts/{appId}/users/{userId}/saving_goals": {
      "schema": "SavingGoal",
      "description": "User's saving goals."
    }
  }
}
